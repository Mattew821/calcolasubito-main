# Global repository protections (root-level)

# Dependencies
**/node_modules/

# Build artifacts
**/.next/
**/out/
**/dist/
**/build/
**/.vercel/

# Environment & secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env*
!**/.env.example

# Certificates / private keys
*.pem
*.key
*.p12
*.pfx

# Local databases / dumps
*.db
*.sqlite
*.sqlite3
*.sql

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test artifacts
**/coverage/
**/playwright-report/
**/test-results/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/settings.local.json
*.swp
*.swo
*~
