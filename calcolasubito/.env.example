# Environment variables - Copia in .env.local e configura

# Base URL for canonical links and sitemap (opzionale, default: https://calcolasubito.vercel.app)
NEXT_PUBLIC_BASE_URL=https://calcolasubito.vercel.app

# Request guard / anti-abuse (opzionale)
# Imposta a true solo per debug locale del middleware in produzione
REQUEST_RATE_LIMIT_DISABLED=false
# Finestra principale e soglia (default: 240 richieste / 60s per IP)
REQUEST_RATE_LIMIT_WINDOW_MS=60000
REQUEST_RATE_LIMIT_MAX_PER_WINDOW=240
# Blocco temporaneo quando supera la soglia principale (default: 10 min)
REQUEST_RATE_LIMIT_BLOCK_MS=600000
# Limite burst per flood improvvisi (default: 80 richieste / 10s per IP)
REQUEST_RATE_LIMIT_BURST_WINDOW_MS=10000
REQUEST_RATE_LIMIT_BURST_MAX=80
# Blocco temporaneo quando supera il burst limit (default: 2 min)
REQUEST_RATE_LIMIT_BURST_BLOCK_MS=120000
# Numero massimo di chiavi IP mantenute in memoria edge
REQUEST_RATE_LIMIT_MAX_KEYS=20000

# Google Analytics (opzionale)
NEXT_PUBLIC_GA_ID=

# Google AdSense (opzionale)
NEXT_PUBLIC_ADSENSE_ID=
