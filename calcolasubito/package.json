{
  "name": "calcolasubito",
  "version": "1.0.0",
  "description": "Suite di calcolatori online SEO-optimized per l'Italia",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "security:scan": "node scripts/security-scan.mjs",
    "verify:full": "npm run security:scan && npm test -- --runInBand && npm run lint && npm run build && npx playwright test",
    "e2e": "npm run build && playwright test",
    "e2e:ui": "npm run build && playwright test --ui",
    "current:update": "node scripts/update-current.mjs",
    "hooks:install": "node scripts/install-hooks.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "codice-fiscale-js": "^2.3.23",
    "comlink": "^4.4.2",
    "gsap": "^3.14.2",
    "lucide-react": "^0.365.0",
    "next": "^14.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.72.0",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.1.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
